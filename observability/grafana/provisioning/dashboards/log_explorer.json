{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Local-dev structured log explorer — v1.0.0 convention",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Volume",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": {} },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "sum by (level) (rate({env=\"$env\", service=~\"$service\"} | json | level=~\"$level\" [$__interval]))",
          "legendFormat": "{{ level }}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log rate by level",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 11,
      "title": "Log stream",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 8 },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "{env=\"$env\", service=~\"$service\"} | json | level=~\"$level\" | domain=~\"$domain\" | trace_id=~\"$trace_id\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Live log stream",
      "type": "logs"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["local-dev", "logging-convention"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values(env)",
        "hide": 0,
        "includeAll": false,
        "label": "Env",
        "multi": false,
        "name": "env",
        "options": [],
        "query": "label_values(env)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": ".*" },
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values(service)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": false,
        "name": "service",
        "options": [],
        "query": "label_values(service)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": ".*" },
        "hide": 0,
        "includeAll": true,
        "label": "Level",
        "multi": true,
        "name": "level",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "DEBUG", "value": "DEBUG" },
          { "selected": false, "text": "INFO",  "value": "INFO"  },
          { "selected": false, "text": "WARN",  "value": "WARN"  },
          { "selected": false, "text": "ERROR", "value": "ERROR" },
          { "selected": false, "text": "FATAL", "value": "FATAL" }
        ],
        "query": "DEBUG,INFO,WARN,ERROR,FATAL",
        "type": "custom"
      },
      {
        "current": { "selected": true, "text": "All", "value": ".*" },
        "hide": 0,
        "includeAll": true,
        "label": "Domain",
        "multi": false,
        "name": "domain",
        "options": [],
        "query": "",
        "type": "textbox"
      },
      {
        "current": { "selected": true, "text": "All", "value": ".*" },
        "hide": 0,
        "includeAll": true,
        "label": "Trace ID",
        "multi": false,
        "name": "trace_id",
        "options": [],
        "query": "",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Local Dev — Log Explorer",
  "uid": "local-dev-log-explorer",
  "version": 1
}
