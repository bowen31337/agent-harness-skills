# harness.config.yaml — generated by harness-skills
# Profile: {{ profile | default('starter') }}
# Generated: {{ timestamp }}

active_profile: {{ profile | default('starter') }}

profiles:
  {{ profile | default('starter') }}:
    gates:
{% for gate in gates %}
      {{ gate.id }}:
        enabled: {{ gate.enabled | default(true) }}
        fail_on_error: {{ gate.fail_on_error | default(true) }}
{% if gate.threshold is defined %}
        threshold: {{ gate.threshold }}
{% endif %}
{% endfor %}
