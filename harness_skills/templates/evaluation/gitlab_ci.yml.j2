stages:
  - evaluate

harness-evaluate:
  stage: evaluate
  image: {{ image | default('python:3.12-slim') }}
  script:
    - {{ install_command | default("uv sync --frozen") }}
    - harness evaluate --output-format json
  artifacts:
    paths:
      - evaluation-report.json
    when: always
    expire_in: 30 days
  rules:
    - if: $CI_MERGE_REQUEST_IID
