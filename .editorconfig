# EditorConfig — consistent formatting across editors and IDEs
# https://editorconfig.org
root = true

# ── Defaults for all files ────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ── Python ────────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 100

# ── YAML / JSON ───────────────────────────────────────────────────────────
[*.{yaml,yml}]
indent_size = 2

[*.json]
indent_size = 2

# ── Shell scripts ─────────────────────────────────────────────────────────
[*.sh]
indent_size = 2

# ── Markdown ──────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false   # trailing spaces are meaningful in Markdown
max_line_length = unset

# ── Makefiles require tabs ────────────────────────────────────────────────
[Makefile]
indent_style = tab

# ── Lock files — never reformat ───────────────────────────────────────────
[*.lock]
insert_final_newline = false
trim_trailing_whitespace = false
